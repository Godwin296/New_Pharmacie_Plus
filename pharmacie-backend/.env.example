# Copie ce fichier en ".env" (jamais commité dans Git) et remplis les vraies valeurs.

# Génère une clé avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplace-moi-par-une-vraie-cle-secrete-generee

DEBUG=True
# ⚠️ Multi-tenant : ALLOWED_HOSTS doit inclure CHAQUE sous-domaine tenant testé en local,
# pas juste "localhost" -- sinon TenantMainMiddleware renvoie 404 avant même que CORS
# n'ait pu ajouter ses en-têtes (le navigateur affiche alors "Network Error", trompeur).
ALLOWED_HOSTS=localhost,127.0.0.1,dupont.localhost,martin.localhost

# PostgreSQL (obligatoire : django-tenants ne fonctionne pas avec SQLite)
DB_NAME=pharmacie_saas
DB_USER=postgres
DB_PASSWORD=remplace-moi
DB_HOST=localhost
DB_PORT=5432

# Idem ici : chaque sous-domaine tenant utilisé en frontend doit apparaître explicitement.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://dupont.localhost:3000,http://martin.localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://dupont.localhost:3000,http://martin.localhost:3000

# 📧 EMAIL TRANSACTIONNEL
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=remplace-moi-par-ton-login-brevo
EMAIL_HOST_PASSWORD=remplace-moi-par-la-cle-smtp-generee
DEFAULT_FROM_EMAIL=Pharmacie Plus <email-verifie@exemple.com>

# 📊 Sentry — laisser vide en dev, remplir en production uniquement
# Obtenir la DSN sur https://sentry.io → New Project → Django
SENTRY_DSN=
APP_VERSION=1.0.0
